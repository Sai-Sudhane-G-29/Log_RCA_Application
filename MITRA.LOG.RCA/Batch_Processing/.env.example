# Environment Variables for Batch Processing Engine

# Application Settings
APP_NAME=Batch Processing Engine
VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/batch_processing

# DorisDB Configuration
DORIS_HOST=localhost
DORIS_PORT=8030
DORIS_USERNAME=root
DORIS_PASSWORD=
DORIS_DATABASE=log_etl

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_APP_NAME=LogETLBatchProcessor
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
JOB_QUEUE_NAME=batch_jobs

# Processing Configuration
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT=3600
BATCH_SIZE=1000
MAX_RETRIES=3
RETRY_DELAY=60

# File Paths
LOG_FILES_PATH=/var/log/batch_processing
PROCESSED_FILES_PATH=/var/log/processed

# Monitoring Configuration
STATUS_CHECK_INTERVAL=30
CLEANUP_INTERVAL=3600

# CORS Configuration
ALLOWED_ORIGINS=["*"]
