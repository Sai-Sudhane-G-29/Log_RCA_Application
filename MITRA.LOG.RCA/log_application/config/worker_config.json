    "default_timeout": 3600,
    "max_retries": 3,
    "retry_delay": 60,
    "progress_update_interval": 5
  },
  "log_analysis": {
    "batch_size": 100,
    "analysis_methods": ["pattern_matching", "anomaly_detection", "correlation"],
    "enable_detailed_logging": true,
    "max_log_size_mb": 50
  }
}