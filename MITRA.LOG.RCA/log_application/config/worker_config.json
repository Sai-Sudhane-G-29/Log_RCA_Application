{
  "celery": {
    "broker_url": null,
    "result_backend": null,
    "task_serializer": "json",
    "result_serializer": "json",
    "accept_content": ["json"],
    "task_track_started": true,
    "worker_concurrency": 4,
    "worker_prefetch_multiplier": 1,
    "task_time_limit": 3600,
    "task_soft_time_limit": 3540
